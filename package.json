{
  "name": "milla-deer-workspace",
  "private": true,
  "version": "1.0.0",
  "description": "Workspace entrypoint for the Milla-Deer repository. The root scripts coordinate the actively supported JavaScript applications while legacy and embedded projects remain preserved in place.",
  "license": "ISC",
  "type": "module",
  "workspaces": [
    "Milla-Rayne",
    "Deer-Milla",
    "Elara2.0",
    "client",
    "server"
  ],
  "scripts": {
    "prepare": "husky install",
    "dev": "pnpm --filter rest-express run dev",
    "dev:all": "pnpm --filter rest-express run dev:all",
    "dev:proactive": "pnpm --filter rest-express run dev:proactive",
    "dev:elara": "pnpm --filter Elara2.0 run dev",
    "cli": "pnpm --filter rest-express run cli",
    "check": "pnpm --filter rest-express run check",
    "check:full": "pnpm --filter rest-express run check:full",
    "lint": "pnpm --filter rest-express run lint",
    "test": "pnpm --filter rest-express run test",
    "build": "pnpm --filter rest-express run build",
    "build:web": "pnpm --filter rest-express run build:web && pnpm --filter Elara2.0 run build",
    "build:milla": "pnpm --filter rest-express run build",
    "build:elara": "pnpm --filter Elara2.0 run build",
    "format": "pnpm --filter rest-express run format",
    "db:push": "pnpm --filter rest-express run db:push",
    "lint-staged": "npx --yes lint-staged",
    "ci": "pnpm run check && pnpm run lint && pnpm run test && pnpm run build",
    "grok": "tsx scripts/grok-cli.ts",
    "dev:grok": "concurrently \"pnpm dev\" \"pnpm run grok\""
  },
  "devDependencies": {
    "@types/uuid": "^10.0.0",
    "husky": "^8.0.3",
    "lint-staged": "^16.4.0",
    "@vibe-kit/grok-cli": "latest",
    "tsx": "^4.20.6",
    "@types/react": "^18.3.3"
  },
  "dependencies": {
    "@langchain/openai": "^1.2.13",
    "langchain": "^1.2.32",
    "n8n-mcp": "^2.37.4",
    "neo4j-driver": "^6.0.1",
    "uuid": "^13.0.0",
    "zod": "^4.3.6"
  }
}
