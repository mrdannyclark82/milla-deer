{
  "name": "milla-deer-workspace",
  "private": true,
  "version": "1.0.0",
  "description": "Workspace entrypoint for the Milla-Deer repository. The root scripts coordinate the actively supported JavaScript applications while legacy and embedded projects remain preserved in place.",
  "license": "ISC",
  "type": "commonjs",
  "workspaces": [
    "Milla-Rayne",
    "Elara2.0"
  ],
  "scripts": {
    "prepare": "husky install",
    "dev": "npm run dev --workspace Milla-Rayne",
    "dev:all": "npm run dev:all --workspace Milla-Rayne",
    "dev:proactive": "npm run dev:proactive --workspace Milla-Rayne",
    "dev:elara": "npm run dev --workspace Elara2.0",
    "cli": "npm run cli --workspace Milla-Rayne",
    "check": "npm run check --workspace Milla-Rayne",
    "check:full": "npm run check:full --workspace Milla-Rayne",
    "lint": "npm run lint --workspace Milla-Rayne",
    "test": "npm run test --workspace Milla-Rayne",
    "build": "npm run build --workspace Milla-Rayne",
    "build:web": "npm run build:web --workspace Milla-Rayne && npm run build --workspace Elara2.0",
    "build:milla": "npm run build --workspace Milla-Rayne",
    "build:elara": "npm run build --workspace Elara2.0",
    "format": "npm run format --workspace Milla-Rayne",
    "db:push": "npm run db:push --workspace Milla-Rayne",
    "lint-staged": "npx --yes lint-staged",
    "ci": "npm run check && npm run lint && npm run test && npm run build"
  },
  "devDependencies": {
    "husky": "^8.0.3",
    "lint-staged": "^16.4.0"
  }
}
